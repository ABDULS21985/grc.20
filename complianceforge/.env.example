# ============================================================
# ComplianceForge GRC Platform — Environment Configuration
# ============================================================

# Application
APP_NAME=complianceforge
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
APP_DEBUG=true
APP_VERSION=1.0.0
APP_BASE_URL=http://localhost:8080
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=complianceforge
DB_PASSWORD=complianceforge
DB_NAME=complianceforge
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300
DB_CONN_MAX_IDLE_TIME=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h

# Encryption (AES-256 key for encrypting sensitive data at rest)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@complianceforge.io
SMTP_FROM_NAME=ComplianceForge

# File Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=eu-west-1
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60s

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Data Residency
DATA_RESIDENCY_REGION=EU
DEFAULT_TIMEZONE=Europe/London
DEFAULT_LANGUAGE=en
